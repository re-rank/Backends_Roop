# ── Neon PostgreSQL ──
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?ssl=require

# ── MongoDB (파일 스토리지) ──
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=reproof

# ── Qdrant (벡터 검색) ──
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Steg.AI (워터마크) ──
STEGAI_API_KEY=
STEGAI_BASE_URL=https://api.steg.ai/v1

# ── C2PA (콘텐츠 인증) ──
C2PA_CERT_PATH=certs/reproof-dev-chain.pem
C2PA_KEY_PATH=certs/reproof-dev-pkcs8.key

# ── Upstash Redis (작업 상태) ──
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# ── QStash (비동기 작업 큐) ──
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ── 모니터링 ──
SENTRY_DSN=
ENVIRONMENT=development

# ── 분석 엔진 ──
ENABLE_EMBEDDING_MODELS=true
ANALYSIS_PHASH_THRESHOLD=0.80
ANALYSIS_VECTOR_THRESHOLD=0.50

# ── 앱 설정 ──
APP_SECRET_KEY=dev-secret-key-change-in-production
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
ALLOW_DIRECT_WORKER_CALLS=false
